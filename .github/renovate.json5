{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>canonical/data-platform//renovate_presets/charm.json5',
  ],
  reviewers: [
    'team:data-postgresql',
  ],
  baseBranchPatterns: [
    'main',
    '/^[0-9][0-9]\\/edge$/',
  ],
  packageRules: [
    {
      matchPackageNames: [
        'pydantic',
      ],
      "matchBaseBranches": ["main"],
      allowedVersions: '<2.0.0',
    },
    {
      matchPackageNames: ['postgresql-charms-single-kernel'],
      schedule: ['* * * * *'],
      minimumReleaseAge: '0',
      groupName: "Single kernel"
    },
  ],
  customManagers: [],
}
